rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Look up the requesting user's role from their profile document.
    // NOTE: This triggers one extra read per rule evaluation. Firestore
    // caches gets within a single request, so cost is bounded.
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasOwnerRole() {
      return isSignedIn() && userRole() == 'SME Owner';
    }

    function hasInventoryRole() {
      return isSignedIn() && (userRole() == 'SME Owner' || userRole() == 'Inventory Manager');
    }

    // Validates a portal document token: must be present, non-empty, and not expired.
    function portalDocValid() {
      return resource.data.accessToken is string
          && resource.data.accessToken.size() >= 32
          && resource.data.expiresAt is timestamp
          && resource.data.expiresAt > request.time;
    }

    function portalWriteValid() {
      return resource.data.accessToken is string
          && resource.data.accessToken.size() >= 32
          && resource.data.expiresAt is timestamp
          && resource.data.expiresAt > request.time;
    }

    // ── Deny all by default ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── User profile ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn()
                  && (request.auth.uid == userId
                      || resource.data.ownerId == request.auth.uid);
      allow update: if isSignedIn()
                    && (request.auth.uid == userId
                        || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;

      // ── Products ─────────────────────────────────────────────────────
      match /products/{productId} {
        allow read: if isOwner(userId);
        allow delete: if isOwner(userId) && hasInventoryRole();
        allow create, update: if isOwner(userId)
          && hasInventoryRole()
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.currentStock is int
          && request.resource.data.currentStock >= 0;
      }

      // ── Suppliers ────────────────────────────────────────────────────
      match /suppliers/{supplierId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Warehouses ───────────────────────────────────────────────────
      match /warehouses/{warehouseId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Demand Records ───────────────────────────────────────────────
      match /demandRecords/{recordId} {
        allow read: if isOwner(userId);
        allow delete: if isOwner(userId) && hasInventoryRole();
        allow create, update: if isOwner(userId)
          && hasInventoryRole()
          && request.resource.data.productId is string
          && request.resource.data.productId.size() > 0
          && request.resource.data.quantity is number
          && request.resource.data.quantity >= 0;
      }

      // ── Settings ─────────────────────────────────────────────────────
      // Only owners can modify settings.
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasOwnerRole();
      }

      // ── Replenishment Approvals ──────────────────────────────────────
      match /approvals/{approvalId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Forecast Results ─────────────────────────────────────────────
      match /forecastResults/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Replenishment Recommendations ────────────────────────────────
      match /replenishmentRecommendations/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Shopify Connection ───────────────────────────────────────────
      match /shopify/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
                     && hasOwnerRole()
                     && docId == 'pending_oauth'
                     && request.resource.data.keys().hasOnly(
                          ['nonce', 'shopDomain', 'createdAt', 'expiresAt']
                        );
      }

      // ── Notifications ────────────────────────────────────────────────
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }

      // ── Analytics Snapshots ──────────────────────────────────────────
      match /analytics/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasOwnerRole();
      }

      // ── Purchase Orders ──────────────────────────────────────────────
      match /purchaseOrders/{orderId} {
        allow read: if isOwner(userId);
        allow delete: if isOwner(userId) && hasInventoryRole();
        // supplierId is intentionally NOT required here: POs can be
        // multi-supplier (supplierId lives on each item, not the header).
        allow create, update: if isOwner(userId)
          && hasInventoryRole()
          && request.resource.data.status is string
          && request.resource.data.status in ['draft', 'pending', 'confirmed',
               'shipped', 'received', 'cancelled', 'sent'];
      }

      // ── Raw Materials ────────────────────────────────────────────────
      match /rawMaterials/{materialId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Bill of Materials ────────────────────────────────────────────
      match /boms/{bomId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Manufacturers ────────────────────────────────────────────────
      match /manufacturers/{manufacturerId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Production Orders ────────────────────────────────────────────
      // Manufacturers can update status on their assigned orders only.
      match /productionOrders/{orderId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId) && hasInventoryRole();
        allow update: if isOwner(userId);
      }

      // ── Raw Material Orders (legacy single-item model) ──────────────
      match /rawMaterialOrders/{orderId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Raw Material Purchase Orders (multi-item model) ──────────────
      match /rawMaterialPurchaseOrders/{orderId} {
        allow read: if isOwner(userId);
        allow delete: if isOwner(userId) && hasInventoryRole();
        allow create, update: if isOwner(userId)
          && hasInventoryRole()
          && request.resource.data.supplierId is string
          && request.resource.data.supplierId.size() > 0
          && request.resource.data.supplierName is string
          && request.resource.data.supplierName.size() > 0
          && request.resource.data.status is string
          && request.resource.data.status in ['draft', 'sent', 'received', 'cancelled']
          && request.resource.data.ownerUid == userId;
      }

      // ── Manufacturing Recommendations ────────────────────────────────
      match /manufacturingRecommendations/{recId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }
      // legacy alias
      match /recommendations/{recId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Cash Flow Snapshots ──────────────────────────────────────────
      match /cashFlowSnapshots/{snapshotId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && hasInventoryRole();
      }

      // ── Workflow Logs ────────────────────────────────────────────────
      // Append-only: create is permitted, update/delete are not.
      match /workflowLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ── Supplier Orders (top-level for portal access) ────────────────────
    // Portal documents require a valid, non-expired accessToken (≥32 chars).
    // The token is set at creation time; clients query by token value.
    // Only field-restricted updates are allowed; deletes are forbidden.
    match /supplierOrders/{orderId} {
      allow read: if portalDocValid();
      allow update: if portalWriteValid()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['response', 'status']);
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.accessToken is string
                    && request.resource.data.accessToken.size() >= 32
                    && request.resource.data.expiresAt is timestamp;
      allow delete: if false;
    }

    // ── Manufacturer Orders (top-level for portal access) ────────────────
    match /manufacturerOrders/{orderId} {
      allow read: if portalDocValid();
      allow update: if portalWriteValid()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'manufacturerNotes', 'completedAt']);
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.accessToken is string
                    && request.resource.data.accessToken.size() >= 32
                    && request.resource.data.expiresAt is timestamp;
      allow delete: if false;
    }

    // ── Factory Orders (top-level for portal access) ─────────────────────
    match /factoryOrders/{orderId} {
      allow read: if portalDocValid();
      allow update: if portalWriteValid()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'factoryNotes', 'estimatedDeliveryDays',
                                 'completedDate']);
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.accessToken is string
                    && request.resource.data.accessToken.size() >= 32
                    && request.resource.data.expiresAt is timestamp;
      allow delete: if false;
    }
  }
}
