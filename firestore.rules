rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Deny all by default ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── User profile ─────────────────────────────────────────────────────
    // Each user can read/write their own profile document.
    // Owners can also read profiles of their team members (ownerId match).
    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || resource.data.ownerId == request.auth.uid);
      allow update: if request.auth != null
                    && (request.auth.uid == userId
                        || resource.data.ownerId == request.auth.uid);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Users cannot delete their own profile

      // ── Products ─────────────────────────────────────────────────────
      match /products/{productId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Suppliers ────────────────────────────────────────────────────
      match /suppliers/{supplierId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Warehouses ───────────────────────────────────────────────────
      match /warehouses/{warehouseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Demand Records ───────────────────────────────────────────────
      match /demandRecords/{recordId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Settings ─────────────────────────────────────────────────────
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Replenishment Approvals ──────────────────────────────────────
      match /approvals/{approvalId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Forecast Results (written by backend, read by client) ────────
      match /forecastResults/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Replenishment Recommendations (written by backend) ───────────
      match /replenishmentRecommendations/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Shopify Connection (read-only from client) ───────────────────
      // Tokens are written by Cloud Functions (admin SDK bypasses rules).
      // Client can only read connection status, not modify tokens.
      match /shopify/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Allow client to write pending_oauth (nonce) but not connection doc
        allow write: if request.auth != null
                     && request.auth.uid == userId
                     && docId == 'pending_oauth';
      }

      // ── Notifications ────────────────────────────────────────────────
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Analytics Snapshots ──────────────────────────────────────────
      match /analytics/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Purchase Orders ──────────────────────────────────────────────
      match /purchaseOrders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Raw Materials ────────────────────────────────────────────────
      match /rawMaterials/{materialId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Bill of Materials ────────────────────────────────────────────
      match /boms/{bomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Manufacturers ────────────────────────────────────────────────
      match /manufacturers/{manufacturerId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Production Orders ────────────────────────────────────────────
      match /productionOrders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Raw Material Orders ──────────────────────────────────────────
      match /rawMaterialOrders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Manufacturing Recommendations ────────────────────────────────
      match /recommendations/{recId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Cash Flow Snapshots ──────────────────────────────────────────
      match /cashFlowSnapshots/{snapshotId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Workflow Logs ────────────────────────────────────────────────
      match /workflowLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Supplier Orders (top-level for portal access) ────────────────────
    // Portal users (suppliers) access by unguessable 32-char access token.
    // Read is open (access control is via the token's secrecy).
    // Update is restricted to portal-safe fields only.
    // Only authenticated owners can create. Deletes disallowed.
    match /supplierOrders/{orderId} {
      allow read: if true;
      allow update: if true
                    && (!resource.data.keys().hasAny(['expiresAt'])
                        || resource.data.expiresAt > request.time)
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['response', 'status']);
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // ── Manufacturer Orders (top-level for portal access) ────────────────
    match /manufacturerOrders/{orderId} {
      allow read: if true;
      allow update: if true
                    && (!resource.data.keys().hasAny(['expiresAt'])
                        || resource.data.expiresAt > request.time)
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'manufacturerNotes', 'completedAt']);
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // ── Factory Orders (top-level for portal access) ─────────────────────
    match /factoryOrders/{orderId} {
      allow read: if true;
      allow update: if true
                    && (!resource.data.keys().hasAny(['expiresAt'])
                        || resource.data.expiresAt > request.time)
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'factoryNotes', 'estimatedDeliveryDays',
                                 'completedDate']);
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }
  }
}
